<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>MailLine</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      background: #e8e8e8;
      display: flex;
      align-items: flex-start;
      justify-content: center;
      min-height: 100vh;
    }

    .page {
      display: none;
    }

    .page.active {
      display: block;
    }

    .wrapper {
      position: relative;
      display: inline-block;
    }

    .page img {
      max-width: 100vw;
      width: 100%;
      height: auto;
      display: block;
    }

    /* Zones cliquables invisibles par-dessus les boutons de navigation */

    /* Bouton "Tableau de bord" dans la sidebar */
    .zone-tableau {
      position: absolute;
      top: 10.5%;
      left: 0%;
      width: 19%;
      height: 7%;
      cursor: pointer;
    }

    /* Bouton "Historique" dans la sidebar */
    .zone-historique {
      position: absolute;
      top: 18%;
      left: 0%;
      width: 19%;
      height: 7%;
      cursor: pointer;
    }

    /* Carte du haut (boite pleine / boite vide) */
    .zone-carte {
      position: absolute;
      top: 6.5%;
      left: 19%;
      width: 81%;
      height: 22%;
      cursor: pointer;
    }
  </style>
</head>
<body>

  <!-- PAGE 1 : Boîte pleine (page principale) -->
  <div class="page active" id="page-pleine">
    <div class="wrapper">
      <img src="data:image/png;base64," alt="Boîte aux lettres pleine" />
      <!-- Clic sur la carte → boîte vide -->
      <div class="zone-carte" onclick="afficherPage('vide')"></div>
      <!-- Clic Historique -->
      <div class="zone-historique" onclick="afficherPage('historique')"></div>
      <!-- Clic Tableau de bord (reste sur pleine) -->
      <div class="zone-tableau" onclick="afficherPage('pleine')"></div>
    </div>
  </div>

  <!-- PAGE 2 : Boîte vide -->
  <div class="page" id="page-vide">
    <div class="wrapper">
      <img src="data:image/png;base64," alt="Boîte aux lettres vide" />
      <!-- Clic sur la carte → boîte pleine -->
      <div class="zone-carte" onclick="afficherPage('pleine')"></div>
      <!-- Clic Tableau de bord → pleine -->
      <div class="zone-tableau" onclick="afficherPage('pleine')"></div>
      <!-- Clic Historique -->
      <div class="zone-historique" onclick="afficherPage('historique')"></div>
    </div>
  </div>

  <!-- PAGE 3 : Historique -->
  <div class="page" id="page-historique">
    <div class="wrapper">
      <img src="data:image/png;base64," alt="Historique" />
      <!-- Clic Tableau de bord → pleine -->
      <div class="zone-tableau" onclick="afficherPage('pleine')"></div>
      <!-- Clic Historique (reste) -->
      <div class="zone-historique" onclick="afficherPage('historique')"></div>
    </div>
  </div>

  <!-- JAVASCRIPT -->
  <script>
    // Cette fonction change la page affichée
    function afficherPage(nomPage) {

      // Etape 1 : on cache TOUTES les pages
      var toutesLesPages = document.querySelectorAll('.page');
      for (var i = 0; i < toutesLesPages.length; i++) {
        toutesLesPages[i].classList.remove('active');
      }

      // Etape 2 : on affiche seulement celle qu'on veut
      if (nomPage === 'pleine') {
        document.getElementById('page-pleine').classList.add('active');
      }
      if (nomPage === 'vide') {
        document.getElementById('page-vide').classList.add('active');
      }
      if (nomPage === 'historique') {
        document.getElementById('page-historique').classList.add('active');
      }
    }
  </script>

</body>
</html>
